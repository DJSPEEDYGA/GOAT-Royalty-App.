{
  "name": "super-goat-royalty",
  "version": "3.1.0",
  "description": "Super GOAT Royalty 3.1 — AI-Powered Music Production & Royalty Management Command Center with 1000+ LLM Integration, Distribution Hub, Beat Maker, Crypto Royalties, Secure Vault, and 22+ Professional Tools",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/DJSPEEDYGA/GOAT-Royalty-App..git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.goatroyalty.superninja",
    "productName": "Super GOAT Royalty",
    "copyright": "Copyright © 2025 Harvey Miller (DJ Speedy) - GOAT Royalty",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "Super-GOAT-Royalty-${version}-Setup.${ext}",
      "sign": null,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.music",
      "artifactName": "Super-GOAT-Royalty-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Audio;Music;Development",
      "artifactName": "Super-GOAT-Royalty-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE"
    },
    "publish": [{ "provider": "github", "owner": "DJSPEEDYGA", "repo": "GOAT-Royalty-App." }]
  },
  "author": {
    "name": "Harvey Miller (DJ Speedy)",
    "email": "djspeedyga@gmail.com"
  },
  "license": "MIT"
}
